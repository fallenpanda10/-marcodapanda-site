{% extends "layouts/base.njk" %}
{% block content %}
<article class="post card">
  <header>
    <h1>{{ title }}</h1>
    <p class="muted">{{ date | date("yyyy-LL-dd") }} • {% if tags %}{% for t in tags %}<a href="/tag/{{ t | slug }}/">{{ t }}</a>{% if not loop.last %}, {% endif %}{% endfor %}{% endif %}</p>
  </header>
  <section class="post-body">
    {{ content | safe }}
  </section>
  <footer>
    <p class="muted">Tags: {% for t in tags %}<a href="/tag/{{ t | slug }}/">{{ t }}</a>{% if not loop.last %}, {% endif %}{% endfor %}</p>
  </footer>
</article>
{% endblock %}
